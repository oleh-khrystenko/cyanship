# BidGuard: Схема Бази Даних (Ultra-MVP)

## Огляд

MongoDB — основна база даних. Мінімальна схема для швидкого старту.

---

## Колекції

### 1. Users

```typescript
interface User {
    _id: ObjectId;

    // Auth (OAuth or Magic Link)
    email: string; // unique, indexed

    // OAuth provider (optional)
    provider?: {
        name: 'google';
        id: string;
    };

    // Profile (from Google or empty)
    profile: {
        name?: string;
        avatar?: string;
    };

    // Credits
    credits: {
        balance: number; // current balance (default: 0)
        freeReportUsed: boolean; // one-time free report used
    };

    // Preferences
    preferredLang: 'uk' | 'en'; // default: 'uk'

    // Meta
    createdAt: Date;
    updatedAt: Date;
    lastLoginAt?: Date;
}

// Indexes
db.users.createIndex({ email: 1 }, { unique: true });
db.users.createIndex({ 'provider.id': 1 }, { sparse: true });
```

### 2. Reports

```typescript
interface Report {
    _id: ObjectId;

    // Relations
    userId: ObjectId; // indexed

    // Photos
    photos: {
        id: string; // UUID
        url: string; // R2 URL
        order: number;
    }[];

    // Analysis Results
    analysis?: {
        issues: {
            id: string;
            type: string; // body_damage, paint_damage, rust, etc.
            severity: 'critical' | 'high' | 'medium' | 'low';
            location: string; // front_bumper, hood, etc.
            description: string;
            repairCost: {
                min: number;
                max: number;
            };
        }[];

        overallScore: number; // 0-100
        verdict: 'RECOMMENDED' | 'CAUTION' | 'NOT_RECOMMENDED';
        verdictExplanation: string;

        totalRepairCost: {
            min: number;
            max: number;
        };
    };

    // Status
    status: 'pending' | 'uploading' | 'processing' | 'completed' | 'failed';
    progress: number; // 0-100
    errorMessage?: string;

    // Timing
    createdAt: Date;
    completedAt?: Date;

    // Payment
    isFreeReport: boolean; // true if used free credit
}

// Indexes
db.reports.createIndex({ userId: 1, createdAt: -1 });
db.reports.createIndex({ status: 1 });
```

### 3. Payments

```typescript
interface Payment {
    _id: ObjectId;

    // Relations
    userId: ObjectId; // indexed

    // Payment details
    provider: 'monobank' | 'wayforpay';
    externalId: string; // provider's payment ID

    amount: number; // in kopiykas (99 грн = 9900)
    currency: 'UAH';

    credits: number; // credits to add (always 1 for MVP)

    // Status
    status: 'pending' | 'completed' | 'failed';

    // Meta
    createdAt: Date;
    completedAt?: Date;
}

// Indexes
db.payments.createIndex({ userId: 1, createdAt: -1 });
db.payments.createIndex({ externalId: 1 }, { unique: true });
db.payments.createIndex({ status: 1 });
```

---

## Redis Keys

```typescript
// Magic Link tokens
`magic:${token}` -> { email: string, expiresAt: number }
// TTL: 15 minutes

// Report processing progress (for polling)
`report:${reportId}:progress` -> { progress: number, step: string }
// TTL: 1 hour

// Rate limiting (global)
`ratelimit:${ip}:${endpoint}` -> number
// TTL: 1 minute

// Rate limiting (magic link per email)
`ratelimit:magic:${email}` -> number
// TTL: 15 minutes, max 3 per window
```

---

## Mongoose Schemas

### User Schema

```typescript
// src/modules/users/schemas/user.schema.ts

import { Prop, Schema, SchemaFactory } from '@nestjs/mongoose';
import { Document } from 'mongoose';

@Schema({ _id: false })
class UserProfile {
    @Prop()
    name?: string;

    @Prop()
    avatar?: string;
}

@Schema({ _id: false })
class UserProvider {
    @Prop({ required: true })
    name: string;

    @Prop({ required: true })
    id: string;
}

@Schema({ _id: false })
class UserCredits {
    @Prop({ default: 0 })
    balance: number;

    @Prop({ default: false })
    freeReportUsed: boolean;
}

@Schema({ timestamps: true })
export class User {
    @Prop({ required: true, unique: true, lowercase: true, trim: true })
    email: string;

    @Prop({ type: UserProvider })
    provider?: UserProvider;

    @Prop({ type: UserProfile, default: {} })
    profile: UserProfile;

    @Prop({ type: UserCredits, default: {} })
    credits: UserCredits;

    @Prop({ default: 'uk' })
    preferredLang!: string;

    @Prop()
    lastLoginAt?: Date;
}

export type UserDocument = User & Document;
export const UserSchema = SchemaFactory.createForClass(User);

UserSchema.index({ email: 1 }, { unique: true });
UserSchema.index({ 'provider.id': 1 }, { sparse: true });
```

### Report Schema

```typescript
// src/modules/reports/schemas/report.schema.ts

import { Prop, Schema, SchemaFactory } from '@nestjs/mongoose';
import { Document, Types } from 'mongoose';

@Schema({ _id: false })
class PhotoItem {
    @Prop({ required: true })
    id: string;

    @Prop({ required: true })
    url: string;

    @Prop({ required: true })
    order: number;
}

@Schema({ _id: false })
class DetectedIssue {
    @Prop({ required: true })
    id: string;

    @Prop({ required: true })
    type: string;

    @Prop({ required: true, enum: ['critical', 'high', 'medium', 'low'] })
    severity: string;

    @Prop({ required: true })
    location: string;

    @Prop({ required: true })
    description: string;

    @Prop({ type: Object, required: true })
    repairCost: { min: number; max: number };
}

@Schema({ _id: false })
class ReportAnalysis {
    @Prop({ type: [DetectedIssue], default: [] })
    issues: DetectedIssue[];

    @Prop({ required: true })
    overallScore: number;

    @Prop({
        required: true,
        enum: ['RECOMMENDED', 'CAUTION', 'NOT_RECOMMENDED'],
    })
    verdict: string;

    @Prop({ required: true })
    verdictExplanation: string;

    @Prop({ type: Object, required: true })
    totalRepairCost: { min: number; max: number };
}

@Schema({ timestamps: true })
export class Report {
    @Prop({ type: Types.ObjectId, ref: 'User', required: true, index: true })
    userId: Types.ObjectId;

    @Prop({ type: [PhotoItem], default: [] })
    photos: PhotoItem[];

    @Prop({ type: ReportAnalysis })
    analysis?: ReportAnalysis;

    @Prop({
        default: 'pending',
        enum: ['pending', 'uploading', 'processing', 'completed', 'failed'],
        index: true,
    })
    status: string;

    @Prop({ default: 0 })
    progress: number;

    @Prop()
    errorMessage?: string;

    @Prop()
    completedAt?: Date;

    @Prop({ default: false })
    isFreeReport: boolean;
}

export type ReportDocument = Report & Document;
export const ReportSchema = SchemaFactory.createForClass(Report);

ReportSchema.index({ userId: 1, createdAt: -1 });
```

### Payment Schema

```typescript
// src/modules/payments/schemas/payment.schema.ts

import { Prop, Schema, SchemaFactory } from '@nestjs/mongoose';
import { Document, Types } from 'mongoose';

@Schema({ timestamps: true })
export class Payment {
    @Prop({ type: Types.ObjectId, ref: 'User', required: true, index: true })
    userId: Types.ObjectId;

    @Prop({ required: true, enum: ['monobank', 'wayforpay'] })
    provider: string;

    @Prop({ required: true, unique: true })
    externalId: string;

    @Prop({ required: true })
    amount: number;

    @Prop({ default: 'UAH' })
    currency: string;

    @Prop({ default: 1 })
    credits: number;

    @Prop({
        default: 'pending',
        enum: ['pending', 'completed', 'failed'],
        index: true,
    })
    status: string;

    @Prop()
    completedAt?: Date;
}

export type PaymentDocument = Payment & Document;
export const PaymentSchema = SchemaFactory.createForClass(Payment);

PaymentSchema.index({ userId: 1, createdAt: -1 });
PaymentSchema.index({ externalId: 1 }, { unique: true });
```

---

## Що НЕ входить в MVP

Ці колекції додамо в Phase 2+:

- `credit_packages` — пакети кредитів
- `promo_codes` — промокоди
- `transactions` — детальна історія транзакцій
- `audit_logs` — логи дій
- `refresh_tokens` — окрема колекція для токенів
</file>

