NODE_ENV=production
WEB_PORT=3000
API_PORT=4000
MONGODB_DB_NAME=bidguard
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
