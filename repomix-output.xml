            it('should set hasActiveSubscription=true for SUBSCRIPTION_UPDATED with TRIALING status', async () => {
                const event: BillingWebhookEvent = {
                    type: BILLING_EVENT_TYPE.SUBSCRIPTION_UPDATED,
