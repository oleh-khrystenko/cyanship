│   ├── i18n/                                      # Конфігурації локалізації
│   │   ├── navigation.ts                          # Мапа локалізованих назв для навігації
│   │   ├── request.ts                             # Отримання поточної мови з запиту
│   │   └── routing.ts                             # Налаштування мовних маршрутів
