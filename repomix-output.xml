MONGODB_DB_NAME: getEnvVar('MONGODB_DB_NAME', 'bidguard'),
WEB_URL: getEnvVar('WEB_URL', 'http://localhost:3000'),

// LAZY REQUIRED — перевіряються при використанні в модулі
