## Technical Details

### Gemini Flash Integration

```typescript
// apps/api/src/modules/reports/ai/ai.service.ts

import { GoogleGenerativeAI } from '@google/generative-ai';

@Injectable()
export class AiService {
    private readonly model: GenerativeModel;

    constructor() {
        const genAI = new GoogleGenerativeAI(ENV.GOOGLE_GEMINI_API_KEY);
        this.model = genAI.getGenerativeModel({ model: 'gemini-2.0-flash' });
    }

    async analyzePhoto(
        imageBuffer: Buffer,
        mimeType: string
    ): Promise<PhotoAnalysis> {
        const result = await this.model.generateContent([
            { text: SYSTEM_PROMPT },
            {
                inlineData: {
                    mimeType,
                    data: imageBuffer.toString('base64'),
                },
            },
        ]);

        return this.parseResponse(result.response.text());
    }
}
```

### System Prompt (Car Inspection)

```
You are an expert vehicle inspector specializing in analyzing auction car photos
from Copart and IAAI. Analyze the provided photo and identify any visible issues.

For each issue found, provide:
- type: category of issue (body_damage, paint_damage, rust, glass_damage,
  tire_damage, interior_damage, mechanical_visible, flood_damage, fire_damage, other)
- severity: critical | high | medium | low
- location: where on the vehicle (front_bumper, rear_bumper, hood, trunk,
  left_door, right_door, roof, windshield, interior, engine_bay, wheels, etc.)
- description: detailed description in English
- repairCost: estimated repair cost in USD { min, max }

Also assess:
- visibleParts: list of vehicle parts visible in this photo
- photoQuality: good | acceptable | poor

Respond ONLY with valid JSON in this exact format:
{
  "issues": [...],
  "visibleParts": [...],
  "photoQuality": "good"
}

If no issues are visible, return empty issues array.
Be conservative — only flag issues you can clearly see.
```

### BullMQ Setup

```typescript
// apps/api/src/modules/reports/reports.module.ts

import { BullModule } from '@nestjs/bullmq';

@Module({
  imports: [
    BullModule.forRoot({ connection: { url: ENV.REDIS_URL } }),
    BullModule.registerQueue({ name: 'report-processing' }),
    // ...
  ],
})
```

### Report Processor

```typescript
// apps/api/src/modules/reports/processors/report.processor.ts

@Processor('report-processing')
export class ReportProcessor extends WorkerHost {
    async process(job: Job<ReportJobData>): Promise<void> {
        const { reportId, photoUrls } = job.data;
        const allIssues: DetectedIssue[] = [];

        for (let i = 0; i < photoUrls.length; i++) {
            // Update progress
            await job.updateProgress({
                progress: Math.round((i / photoUrls.length) * 100),
                step: `Analyzing photo ${i + 1} of ${photoUrls.length}`,
            });

            // Download photo from R2
            const imageBuffer = await this.downloadPhoto(photoUrls[i]);

            // Send to Gemini
            const analysis = await this.aiService.analyzePhoto(
                imageBuffer,
                'image/jpeg'
            );

            // Collect issues
            allIssues.push(...analysis.issues);
        }

        // Aggregate results
        const aggregated = this.aggregateIssues(allIssues);

        // Save to MongoDB
        await this.reportsService.completeReport(reportId, aggregated);
    }
}
```

### Verdict Calculation

```typescript
import type { DetectedIssue, Verdict } from '@bidguard/types';

function calculateVerdict(issues: DetectedIssue[]): {
    score: number;
    verdict: Verdict;
    explanation: string;
} {
    let score = 100;

    for (const issue of issues) {
        switch (issue.severity) {
            case 'critical':
                score -= 25;
                break;
            case 'high':
                score -= 15;
                break;
            case 'medium':
                score -= 8;
                break;
            case 'low':
                score -= 3;
                break;
        }
    }

    score = Math.max(0, Math.min(100, score));

    const verdict: Verdict =
        score >= 75
            ? 'RECOMMENDED'
            : score >= 40
              ? 'CAUTION'
              : 'NOT_RECOMMENDED';

    return {
        score,
        verdict,
        explanation: generateExplanation(verdict, issues),
    };
}
```

### Polling Strategy (Frontend)

```typescript
import type { ReportStatus } from '@bidguard/types';

// Poll every 2 seconds until completed or failed
function useReportStatus(reportId: string) {
    const [status, setStatus] = useState<ReportStatus>('processing');
    const [progress, setProgress] = useState(0);

    useEffect(() => {
        const interval = setInterval(async () => {
            const data = await getReportStatus(reportId);
            setStatus(data.status);
            setProgress(data.progress);

            if (data.status === 'completed' || data.status === 'failed') {
                clearInterval(interval);
            }
        }, 2000);

        return () => clearInterval(interval);
    }, [reportId]);

    return { status, progress };
}
```

