# ============================================================
# FAIL FAST POLICY:
# ALL variables below are REQUIRED. The app will crash on
# startup if any are missing. Do NOT add fallback/default
# values in code — silent failures are invisible in production.
#
# Only exceptions (have defaults in code):
#   NODE_ENV (development), PORT (4000),
#   MONGODB_DB_NAME (bidguard), WEB_URL (http://localhost:3000)
# ============================================================

NODE_ENV=development

WEB_PORT=3000
# API uses PORT internally (Railway sets PORT automatically)
API_PORT=4000

# MongoDB (Atlas or local) — REQUIRED, no fallback
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<app>
MONGODB_DB_NAME=bidguard

# Redis — REQUIRED, no fallback
REDIS_URL=redis://localhost:6379

# Auth — REQUIRED, no fallback. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=<generate-random-32-byte-hex>
JWT_REFRESH_SECRET=<generate-random-32-byte-hex>
WEB_URL=http://localhost:3000

# Public URLs — REQUIRED, no fallback. Critical for SEO (canonical URLs, Open Graph)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Cloudflare R2 — REQUIRED, no fallback
R2_ACCOUNT_ID=your_account_id
R2_BUCKET_NAME=bidguard-uploads
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-<id>.r2.dev

# Google OAuth — REQUIRED, no fallback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Google AI (Gemini) — REQUIRED, no fallback
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# Resend (email) — REQUIRED, no fallback
RESEND_API_KEY=re_your_resend_api_key
