cyanship.com {
    reverse_proxy 127.0.0.1:3000

    tls /etc/caddy/tls/origin.pem /etc/caddy/tls/origin-key.pem

    encode zstd gzip

    header {
        # Prevent MIME-type sniffing
        X-Content-Type-Options nosniff
        # Clickjacking protection
        X-Frame-Options DENY
        # Disable referrer on cross-origin
        Referrer-Policy strict-origin-when-cross-origin
        # 1 year HSTS, all subdomains, preload-eligible. Cloudflare in front does not send HSTS by default;
        # this header reaches the browser via CF and pins HTTPS for cyanship.com + *.cyanship.com.
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Disable browser features the app doesn't need
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(self)"
        # Cross-origin isolation safe-defaults
        Cross-Origin-Opener-Policy same-origin
        # Remove server identity
        -Server
    }

    log {
        output file /var/log/caddy/cyanship.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
