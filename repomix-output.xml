                    {
                        $set: expect.objectContaining({
                            'billing.hasActiveSubscription': true,
                            'billing.subscriptionStatus':
                                SUBSCRIPTION_STATUS.ACTIVE,
                            'billing.currentPeriodEnd': currentPeriodEnd,
                            'billing.cancelAtPeriodEnd': false,
                        }),
                    },
                    { maxTimeMS: 10000 }
