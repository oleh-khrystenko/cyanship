JWT_ACCESS_SECRET: getEnvVar('JWT_ACCESS_SECRET'),   // no fallback
JWT_REFRESH_SECRET: getEnvVar('JWT_REFRESH_SECRET'), // no fallback
REDIS_URL: getEnvVar('REDIS_URL'),             // no fallback

